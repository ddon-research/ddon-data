# Ghidra Analysis Environment Configuration Template
# Copy this file to .env and update the paths for your specific environment

# PyGhidra executable path
# Location of the pyghidraRun script in your Ghidra installation
# Example: "C:/Ghidra/ghidra_11.4.2_PUBLIC/support/pyghidraRun" (Windows)
# Example: "/opt/ghidra/support/pyghidraRun" (Linux)
PYGHIDRA_RUN="PATH_TO_GHIDRA/support/pyghidraRun"

# Ghidra project configuration
# Directory where your Ghidra project is located
PROJECT_DIR="PATH_TO_YOUR_PROJECT_DIRECTORY"
# Name of your Ghidra project
PROJECT_NAME="YOUR_PROJECT_NAME"

# Script paths
# Directory containing the analysis scripts (usually this directory)
SCRIPTS_BASE_DIR="PATH_TO_DDON_DATA/research/ghidra/headless-scripts"

# Binary Analyzer Scripts
# These paths point to the analyzer scripts
SYMBOL_EXPLORER_SCRIPT="ddon-binary-analyzer/main_symbol_explorer_simple.py"
FUNCTION_ANALYZER_SCRIPT="ddon-binary-analyzer/main_function_analyzer_simple.py"

# Default parameter values
# Default logging level: "DEBUG" for detailed output, "INFO" for normal output
DEFAULT_LOG_LEVEL="INFO"
# Default exploration depth for DWARF symbol analysis (1-10)
DEFAULT_EXPLORE_DEPTH=5
# Default maximum recursion depth for function analysis (1-10)
DEFAULT_MAX_DEPTH=3

# Environment variables for VS Code type support
# Ghidra installation directory (used by VS Code settings for IntelliSense)
GHIDRA_INSTALL_DIR="PATH_TO_GHIDRA"

# Configuration Examples:
